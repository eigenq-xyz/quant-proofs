# Claude Code — local settings, worktrees, and project memory (not for public repo)
.claude/settings.local.json
.claude/worktrees/
.claude/projects/
.claude/scheduled_tasks.lock

# Lean build artifacts
**/.lake/
**/lake-packages/

# Python build artifacts
**/__pycache__/
**/*.pyc
**/*.pyo
**/.venv/
**/build/
**/dist/
**/*.egg-info/
**/.mypy_cache/
**/.pytest_cache/
**/.ruff_cache/

# Cython compiled extensions
**/*.so
**/*.pyd

# Data directories (licensed data — never commit)
**/data/*.parquet
**/data/*.csv
**/data/*.h5
**/data/*.arrow
**/data/raw/
**/data/processed/

# Jupyter
**/.ipynb_checkpoints/
**/*_files/
# Quarto rendered output (scenarios + reports): committed so GitHub renders the markdown
!portfolio-proofs/scenarios/**/*_files/
!portfolio-proofs/reports/**/*_files/

# macOS
**/.DS_Store
.claude/worktrees/

