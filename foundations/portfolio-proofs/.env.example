# Copy to .env and fill in values before running docker compose or dvc push/pull.
# .env is git-ignored; this file is committed as a template.

# MinIO credentials (local S3-compatible store)
MINIO_ROOT_USER=quantproofs
MINIO_ROOT_PASSWORD=quantproofs123

# DVC remote — set in .dvc/config.local (also git-ignored).
# Run once after cloning:
#   dvc remote modify --local minio-local access_key_id     <MINIO_ROOT_USER>
#   dvc remote modify --local minio-local secret_access_key <MINIO_ROOT_PASSWORD>
